generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  SELLER
  ADMIN
}

enum OrderStatus {
  Pending
  Shipped
  Completed
}

enum PaymentProvider {
  PAYPAL
  STRIPE
}

enum PaymentState {
  Pending
  Processing
  Paid
  Failed
  Canceled
  Refunded
}

model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  name          String?
  email         String?   @unique
  passwordHash  String?
  bio           String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(CUSTOMER)
  hasActivePack Boolean   @default(false)
  address       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  purchases     Purchase[]
  products      Product[]
  cartItems     CartItem[]
  orders        Order[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  notifications Notification[]
  followers     Follow[]  @relation("UserFollowers")
  following     Follow[]  @relation("UserFollowing")
  sellerProfile SellerProfile?
  sentMessages  SellerMessage[] @relation("SellerMessageSender")
  receivedMessages SellerMessage[] @relation("SellerMessageRecipient")
  sellerConversations SellerMessage[] @relation("SellerConversationSeller")
  auditLogs     AuditLog[] @relation("AuditActor")
  errorLogs     ErrorLog[] @relation("ErrorActor")
}

model SellerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  storeName     String?
  description   String?
  coverImageUrl String?
  avatarUrl     String?
  isVerified    Boolean  @default(false)
  instagramUrl  String?
  facebookUrl   String?
  tiktokUrl     String?
  youtubeUrl    String?
  telegramUrl   String?
  twitterUrl    String?
  whatsappUrl   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  body        String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorId    String?

  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model Product {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String
  category    String      @default("General")
  priceCents  Int
  imageUrl    String?
  stock       Int         @default(1)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sellerId    String

  seller      User        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  purchases   Purchase[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  reviews     Review[]
  wishlistItems WishlistItem[]
}

model Purchase {
  id             String    @id @default(cuid())
  userId         String
  productId      String
  status         String    @default("active")
  purchasedAt    DateTime  @default(now())
  expiresAt      DateTime?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model CartItem {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id         String      @id @default(cuid())
  userId     String
  totalCents Int
  status     OrderStatus @default(Pending)
  paymentProvider PaymentProvider @default(PAYPAL)
  paymentState    PaymentState    @default(Pending)
  currencyCode    String          @default("USD")
  paymentReference String?
  paymentCapturedAt DateTime?
  shippingAddress String?
  shippingCostCents Int   @default(0)
  deliveryEtaDays   Int   @default(5)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      OrderItem[]
  paymentRecord PaymentRecord?
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  quantity      Int
  unitPriceCents Int

  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PaymentRecord {
  id                String          @id @default(cuid())
  orderId           String          @unique
  provider          PaymentProvider
  status            PaymentState    @default(Pending)
  amountCents       Int
  currencyCode      String          @default("USD")
  providerOrderId   String?
  providerSessionId String?
  providerPaymentId String?
  payerEmail        String?
  payerName         String?
  paymentMethodType String?
  cardBrand         String?
  cardLast4         String?
  countryCode       String?
  receiptUrl        String?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([provider, status])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model SellerMessage {
  id          String   @id @default(cuid())
  sellerId    String
  senderId    String
  recipientId String
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  seller      User     @relation("SellerConversationSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  sender      User     @relation("SellerMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("SellerMessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
  @@index([senderId, createdAt])
  @@index([recipientId, isRead, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  target     String
  details    String
  createdAt  DateTime @default(now())
  actorId    String?

  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model ErrorLog {
  id         String   @id @default(cuid())
  message    String
  source     String
  stack      String?
  createdAt  DateTime @default(now())
  actorId    String?

  actor      User?    @relation("ErrorActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
